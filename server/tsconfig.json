{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "./dist",
		"rootDir": "..",
		"declaration": true,
		"sourceMap": true,
		"resolveJsonModule": true,
		"types": ["node"]
	},
	"include": ["./**/*.ts", "../shared/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
